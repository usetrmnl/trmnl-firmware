# Per-target ESP-IDF sdkconfigs are committed under sdkconfigs/.
# Ignore any sdkconfig.* generated at the repo root (legacy / non-redirected envs).
/sdkconfig.*

# Backups generated by menuconfig
/sdkconfigs/*.old

# These per-target configs are build-generated and intentionally not committed.
/sdkconfigs/sdkconfig.trmnl
/sdkconfigs/sdkconfig.trmnl_4clr
/sdkconfigs/sdkconfig.trmnl_gen2
/sdkconfigs/sdkconfig.local

# Handled by espressif
managed_components/

# Integration test environment (contains secrets)
test/integration/test_config.h
dependencies.lock
